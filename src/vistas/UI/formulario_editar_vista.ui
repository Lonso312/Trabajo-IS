<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>FormularioEditarDialog</class>
 <widget class="QDialog" name="FormularioEditarDialog">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>480</width>
    <height>600</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>Ficha de Datos de Miembro</string>
  </property>
  <layout class="QVBoxLayout" name="layout_principal">

   <!-- Campos de texto: DNI, Nombre, Apellido, Teléfono, Correo, Grado, Rol -->
   <item>
    <layout class="QGridLayout" name="grid_campos">

     <item row="0" column="0"><widget class="QLabel" name="l1"><property name="text"><string>DNI:</string></property></widget></item>
     <item row="0" column="1"><widget class="QLineEdit" name="txt_dni"/></item>

     <item row="1" column="0"><widget class="QLabel" name="l2"><property name="text"><string>Nombre:</string></property></widget></item>
     <item row="1" column="1"><widget class="QLineEdit" name="txt_nombre"/></item>

     <item row="2" column="0"><widget class="QLabel" name="l3"><property name="text"><string>Apellido:</string></property></widget></item>
     <item row="2" column="1"><widget class="QLineEdit" name="txt_apellido"/></item>

     <item row="3" column="0"><widget class="QLabel" name="l4"><property name="text"><string>Teléfono:</string></property></widget></item>
     <item row="3" column="1"><widget class="QLineEdit" name="txt_telefono"/></item>

     <item row="4" column="0"><widget class="QLabel" name="l5"><property name="text"><string>Correo Universitario:</string></property></widget></item>
     <item row="4" column="1"><widget class="QLineEdit" name="txt_correo"/></item>

     <item row="5" column="0"><widget class="QLabel" name="l6"><property name="text"><string>Grado:</string></property></widget></item>
     <item row="5" column="1"><widget class="QComboBox" name="cb_grado"/></item>

     <item row="6" column="0"><widget class="QLabel" name="l7"><property name="text"><string>Rol Sistema:</string></property></widget></item>
     <item row="6" column="1"><widget class="QComboBox" name="cb_rol"/></item>

     <!-- Departamentos: label + scroll en filas separadas -->
     <item row="7" column="0"><widget class="QLabel" name="l8"><property name="text"><string>Departamentos:</string></property></widget></item>
     <item row="8" column="0" colspan="2">
      <widget class="QScrollArea" name="scroll_deptos">
       <property name="widgetResizable"><bool>true</bool></property>
       <property name="minimumSize"><size><width>0</width><height>90</height></size></property>
       <property name="maximumSize"><size><width>16777215</width><height>120</height></size></property>
       <widget class="QWidget" name="widget_contenido_deptos">
        <property name="geometry"><rect><x>0</x><y>0</y><width>440</width><height>90</height></rect></property>
        <layout class="QVBoxLayout" name="layout_deptos_dinamicos"/>
       </widget>
      </widget>
     </item>

     <!-- Grupos: label + scroll en filas separadas -->
     <item row="9" column="0"><widget class="QLabel" name="l9"><property name="text"><string>Grupos de Trabajo:</string></property></widget></item>
     <item row="10" column="0" colspan="2">
      <widget class="QScrollArea" name="scroll_grupos">
       <property name="widgetResizable"><bool>true</bool></property>
       <property name="minimumSize"><size><width>0</width><height>90</height></size></property>
       <property name="maximumSize"><size><width>16777215</width><height>120</height></size></property>
       <widget class="QWidget" name="widget_contenido_grupos">
        <property name="geometry"><rect><x>0</x><y>0</y><width>440</width><height>90</height></rect></property>
        <layout class="QVBoxLayout" name="layout_grupos_dinamicos"/>
       </widget>
      </widget>
     </item>

    </layout>
   </item>

   <!-- Botones OK / Cancel -->
   <item>
    <widget class="QDialogButtonBox" name="buttons">
     <property name="standardButtons"><set>QDialogButtonBox::Cancel|QDialogButtonBox::Ok</set></property>
    </widget>
   </item>

  </layout>
 </widget>
</ui>